# Copy this file to .taskfile.env and fill in your project-specific values.
# .taskfile.env is gitignored by default.
# Run scripts/install.sh to generate this automatically.

# Project identifier — used as default Kubernetes namespace
NAMESPACE=my-project

# AWS settings
AWS_REGION=eu-central-1
AWS_PROFILE_DEV=my-dev-profile
AWS_PROFILE_PLAY=my-playground-profile

# Azure settings
# Optional default subscription used by azure:* tasks.
AZURE_SUBSCRIPTION_ID=

# Kubernetes context to use for all kube:* and diagnostics:* tasks.
# Leave empty to use the currently active context (kubectl config current-context).
KUBE_CONTEXT=my-cluster

# Directory where diagnostics and security scan output is written.
OUTPUT_DIR=.diagnostics
